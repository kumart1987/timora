{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist/frontend/browser",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node",
      "includeFiles": "backend/.env"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/uploads/:path*", "destination": "/backend/uploads/:path*" }
  ]
}
