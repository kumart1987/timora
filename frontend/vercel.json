{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/frontend/browser",
  "functions": {
    "api/index.js": {
      "includeFiles": ".env"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/uploads/:path*", "destination": "/../backend/uploads/:path*" }
  ]
}
